# AgentOrion - Configuración de Proveedor de IA
# Copia este archivo como .env y ajusta los valores

# API Key de tu proveedor de IA
OPENAI_API_KEY=sk-tu-api-key-aqui

# Modelo a usar (opcional, default: gpt-4.1)
MODEL=gpt-4.1

# Tipo de proveedor: openai | azure | anthropic (opcional, default: openai)
PROVIDER_TYPE=openai

# Base URL del proveedor (opcional, default: https://api.openai.com/v1)
# Para Ollama local: http://localhost:11434/v1
# Para Azure: https://tu-recurso.openai.azure.com
PROVIDER_BASEURL=https://api.openai.com/v1
